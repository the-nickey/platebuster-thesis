# Скопируй этот файл в .env и заполни значения.
# .env в .gitignore — никогда не коммить.

# Roboflow API ключ (бесплатный, для скачивания публичных датасетов).
# Где взять: https://app.roboflow.com/settings/api
# 1. Зарегайся бесплатно если нет аккаунта.
# 2. Settings → API Keys → Private API Key (Copy).
ROBOFLOW_API_KEY=

# (Опционально) Yandex.Cloud / W&B и пр. — добавим позже на этапе обучения.
